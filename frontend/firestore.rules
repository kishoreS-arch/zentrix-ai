rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /login_history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ✅ Chats — user can only access their own sessions
    match /chats/{chatId} {
      // On CREATE: the new doc must carry the logged-in user's uid
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      
      // On READ / UPDATE / DELETE: the existing doc must belong to them
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;

      // Messages sub-collection: allowed if parent chat belongs to user
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
